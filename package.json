    "url": "git+https://github.com/MuWinds/tabby-server-status.git"
  },
  "bugs": {
    "url": "https://github.com/MuWinds/tabby-server-status/issues"
  },
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch"
  },
  "files": [
    "dist"
  ],
