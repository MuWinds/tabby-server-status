    "pug": "3.0.2",
    "pug-loader": "2.4.0",
    "rxjs": "7.8.1",
    "sass": "1.69.5",
    "sass-loader": "13.3.2",
    "to-string-loader": "1.2.0",
    "ts-loader": "9.5.1",
    "typescript": "5.2.2",
    "webpack": "5.89.0",
    "webpack-cli": "5.1.4",
    "zone.js": "0.13.3"
  }
}
